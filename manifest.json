{
  "manifest_version": 3,
  "name": "TabHavoc Cat",
  "version": "1.0",
  "description": "A cat that wreaks havoc on your tabs if you're inactive.",
  "permissions": [
    "storage",
    "alarms",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/interaction.js",
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ]
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html"
  }
}